# Notion — internal integration (keep secret; use .env.local locally, Vercel env in production)
# Create at https://www.notion.so/my-integrations → New integration → copy "Internal Integration Secret"
NOTION_TOKEN=

# Open your CRM / inquiries database in Notion → Share → invite the integration → Copy link ID from URL
# URL looks like: https://www.notion.so/workspace/DATABASE_ID?v=...
NOTION_CONTACT_DATABASE_ID=2552d5cd4ef481e18881c88cefe41e03

# Optional — only if your database property NAMES differ from these defaults (case-sensitive):
# NOTION_PROP_TITLE=Name
# NOTION_PROP_EMAIL=Email
# NOTION_PROP_LINKEDIN=LinkedIn
# NOTION_PROP_BUDGET=Budget
# NOTION_PROP_TIMELINE=Timeline
# NOTION_PROP_DETAILS=Details
